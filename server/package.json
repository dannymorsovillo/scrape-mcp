{
  "name": "api-scraper-mcp-server",
  "version": "0.1.0",
  "description": "Bridge that receives scraped API endpoints over WebSocket and exposes them to AI agents as MCP tools",
  "type": "module",
  "bin": {
    "api-scraper-mcp": "./dist/index.js"
  },
  "scripts": {
