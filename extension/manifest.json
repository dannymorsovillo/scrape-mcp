{
  "manifest_version": 3,
  "name": "API Scraper",
  "version": "0.1.0",
  "description": "Captures XHR/fetch API calls on the current tab and streams them to the local api-scraper-mcp bridge.",
  "permissions": ["debugger", "storage", "tabs"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "API Scraper"
  }
}
